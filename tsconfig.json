{
  "compilerOptions": {
    "target": "ES2023",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "verbatimModuleSyntax": false,

    "sourceMap": true
  },

  "include": ["src"]
}